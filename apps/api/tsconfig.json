{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "Node",
    "target": "ES2022",
    "outDir": "./dist",
    "rootDir": "./src",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "declaration": true,
    "types": ["node"],
    // Prisma-generated Client types are incompatible with
    // exactOptionalPropertyTypes (optional fields are typed as `T` not
    // `T | undefined`, but the client accepts `undefined` at runtime).
    // Relax for the api app only — shared stays strict.
    "exactOptionalPropertyTypes": false
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
